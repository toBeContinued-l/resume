# MySQL 连接字符串。生产/联调填写真实数据库；留空时使用内存仓储。
# 示例：mysql://user:password@localhost:3306/online_resume
DATABASE_URL="mysql://user:password@localhost:3306/online_resume"

# RabbitMQ 连接字符串。生产/联调填写真实 MQ；留空时使用内存队列。
# 示例：amqp://user:password@localhost:5672/vhost
RABBITMQ_URL="amqp://localhost:5672"

# 上传文件临时目录。需要当前进程可写。
# 示例：/tmp/online-resume
TEMP_UPLOAD_ROOT="/tmp/online-resume"

# 推荐的新 AI 配置，用于 cc switch 或 OpenAI 兼容中转站。
# AI_API_KEY：中转站 API Key。
# AI_MODEL：中转站模型名。
# AI_API_REQUEST_URL：完整请求地址，支持 /v1/chat/completions 或 /v1/responses。
# AI_API_BASE_URL：基础地址；只填它时系统会自动拼接 /responses。
# 示例：
# AI_API_KEY="sk-..."
# AI_MODEL="gpt-5.4"
# AI_API_REQUEST_URL="https://relay.example.com/v1/chat/completions"
# AI_API_BASE_URL="https://relay.example.com/v1"
AI_API_KEY=""
AI_MODEL="gpt-4o-mini"
AI_API_REQUEST_URL=""
AI_API_BASE_URL=""

# 兼容旧 OpenAI 命名。当前仍可使用；如果 AI_* 和 OPENAI_* 同时存在，优先使用 AI_*。
# OPENAI_ENDPOINT 既可以填完整请求地址，也可以填中转站根地址，根地址会自动补成 /v1/chat/completions。
# 示例：
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-5.4"
# OPENAI_ENDPOINT="https://ai.example.com"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_ENDPOINT=""
OPENAI_BASE_URL=""

# 外部 smoke 测试开关。默认关闭，避免日常测试依赖外部服务。
RUN_MYSQL_INTEGRATION="0"
RUN_RABBITMQ_INTEGRATION="0"

# 邮件配置。mock 表示本地内存邮件 provider，不真正发信；smtp 表示使用真实 SMTP 发信。
# 真实邮箱验证需要配置 SMTP。常见端口：465 通常 SMTP_SECURE=true，587 通常 SMTP_SECURE=false。
# 示例：
# MAIL_PROVIDER="smtp"
# MAIL_FROM="Online Resume <no-reply@example.com>"
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="465"
# SMTP_SECURE="true"
# SMTP_USER="no-reply@example.com"
# SMTP_PASSWORD="smtp-password-or-app-password"
MAIL_PROVIDER="mock"
MAIL_FROM="no-reply@example.com"
SMTP_HOST="smtp.example.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="no-reply@example.com"
SMTP_PASSWORD="smtp-password-or-app-password"

# Redis 用于邮箱验证码。密码包含 $ 时，在 .env.local 中需要写成 \$。
# 示例：
# REDIS_HOST="127.0.0.1"
# REDIS_PORT="6379"
# REDIS_DATABASE="1"
# REDIS_PASSWORD="redis-password"

# 应用外部访问地址，用于邮件链接和公开链接生成。
APP_BASE_URL="http://localhost:3000"

# 会话签名密钥。生产环境需要替换成长随机字符串。
SESSION_SECRET="replace-with-a-long-random-secret"
